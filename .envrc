# Automatische venv-Aktivierung mit direnv
# Installation: sudo apt install direnv
# Aktivierung: echo 'eval "$(direnv hook bash)"' >> ~/.bashrc
# Dann: direnv allow

# Lade .env falls vorhanden
dotenv_if_exists

# Aktiviere uv venv
if [[ -d .venv ]]; then
    source .venv/bin/activate
elif command -v uv &> /dev/null; then
    # Erstelle venv falls nicht vorhanden
    uv venv
    source .venv/bin/activate
fi

# PYTHONPATH auf src setzen
export PYTHONPATH="${PWD}/src:${PYTHONPATH}"
